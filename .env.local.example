# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Unsplash (Phase 4+)
UNSPLASH_ACCESS_KEY=

# Anthropic API (optional, Phase 5+)
# Leave empty to use manual copy-to-clipboard workflow for hooks/conversion.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
API_MONTHLY_CAP=5

# WhisperX transcription settings.
# Defaults are tuned conservatively for 8GB VRAM (RTX 4060 Ti) with browser/
# Discord/etc. also open. Bump for bigger cards or tighter envs:
#   8GB (nothing else open): WHISPERX_BATCH_SIZE=4
#   16GB: WHISPERX_BATCH_SIZE=8, WHISPERX_COMPUTE_TYPE=float16
#   24GB: WHISPERX_BATCH_SIZE=16, WHISPERX_COMPUTE_TYPE=float16
# If large-v3 still OOMs on 8GB with batch 1, switch to WHISPERX_MODEL=medium.
# large-v3-turbo: same architecture as large-v3 but 4 decoder layers
# instead of 32 — 3-5x faster inference, near-identical English accuracy,
# slightly worse Arabic (hafiz catches misses manually). Fallback to
# 'large-v3' or 'medium' if you need max Arabic accuracy.
WHISPERX_MODEL=large-v3-turbo
WHISPERX_DEVICE=cuda
WHISPERX_COMPUTE_TYPE=int8_float16
WHISPERX_BATCH_SIZE=4
# Timeout in ms. Default 6h. Set to 0 to disable entirely.
WHISPERX_TIMEOUT_MS=21600000

# Binary overrides — only needed if not on PATH.
# YTDLP_BIN=C:\\path\\to\\yt-dlp.exe
# FFMPEG_BIN=C:\\path\\to\\ffmpeg.exe
# PYTHON_BIN=C:\\path\\to\\python.exe

# Windows / Microsoft Store Python users: pip-installed yt-dlp often lives
# in a sandboxed path that isn't on PATH. Set this instead of YTDLP_BIN
# and the app will invoke `python -m yt_dlp` directly.
# YTDLP_USE_PYTHON=1

DOWNLOADS_DIR=./downloads
BACKGROUNDS_DIR=./backgrounds
RECITATIONS_DIR=./recitations
RENDERS_DIR=./renders
